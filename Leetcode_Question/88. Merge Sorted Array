class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
        int merge[] = new int[m + n];
        System.arraycopy(nums1, 0, merge, 0, m);
        System.arraycopy(nums2, 0, merge, m, n);

        Arrays.sort(merge);
        int i=0;
        for(int nums : merge){
            nums1[i++] = nums;
        }
    }
}
